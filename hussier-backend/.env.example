# === Configuration backend Huissier App ===
# Copier ce fichier en .env et renseigner les valeurs de production.

# Base de donnees PostgreSQL
DATABASE_URL=postgresql://UTILISATEUR:MOTDEPASSE@HOTE:5432/NOM_BASE

# Securite — OBLIGATOIRE en production.
# Generer une cle: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGEZ_MOI_CLE_ALEATOIRE
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — domaines autorises du frontend (separes par des virgules)
BACKEND_CORS_ORIGINS=https://app.mondomaine.com,https://www.mondomaine.com

# Upload
UPLOAD_DIR=uploads

# Email (optionnel)
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@mondomaine.com
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587

# Redis (optionnel)
# REDIS_URL=redis://localhost:6379/0
